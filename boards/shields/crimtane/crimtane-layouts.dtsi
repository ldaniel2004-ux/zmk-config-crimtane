#include <physical_layouts.dtsi>

/ {
    // =========================================================================
    // 1. MAIN SPLIT KEYBOARD LAYOUT
    // =========================================================================
    crimtane_layout: crimtane_layout {
        compatible = "zmk,physical-layout";
        display-name = "Crimtane Split Keyboard";
	transform = <&default_transform>;
    };

};

/ {
    // Satisfies the numpad build before crimtane.dtsi loads
    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <0>;
        rows = <0>;
        map = <>;
    };

};