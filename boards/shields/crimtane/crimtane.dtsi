#include <dt-bindings/zmk/matrix_transform.h>

#include "crimtane-layouts.dtsi"

/ {
    chosen {
        zmk,kscan = &kscan;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <6>;
//  nice!nano_v2
// | 024,010 | 100,010 | 011,010 | 104,010 | 106,010 | 022,010 | 020,010 |	| 106,010 | 104,010 | 011,010 | 100,010 | 024,010 | 022,010 | 020,010 |
